<?xml version="1.0"?>
<!DOCTYPE service_bundle SYSTEM "/usr/share/lib/xml/dtd/service_bundle.dtd.1">

<service_bundle type='manifest' name='ramdisk-postboot'>

<service name='site/ramdisk/postboot' type='service' version='1'>
  <create_default_instance enabled='true' />

  <!-- Run once we hit multi-user, so that the network and file systems have
    been set up. -->
  <dependency name='multi-user' grouping='require_all' restart_on='none'
    type='service'>
    <service_fmri value='svc:/milestone/multi-user' />
  </dependency>

  <exec_method type='method' name='start'
    exec='/usr/lib/ramdisk_postboot'
    timeout_seconds='3600' />

  <exec_method type='method' name='stop' exec=':true' timeout_seconds='3' />

  <property_group name='startd' type='framework'>
    <propval name='duration' type='astring' value='transient' />
  </property_group>

  <stability value='Unstable' />

  <template>
    <common_name>
      <loctext xml:lang='C'>ramdisk postboot</loctext>
    </common_name>
    <description>
      <loctext xml:lang='C'>ramdisk postboot</loctext>
    </description>
  </template>
</service>

</service_bundle>
